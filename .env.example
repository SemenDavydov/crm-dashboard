# RetailCRM
RETAILCRM_URL=https://YOUR_SUBDOMAIN.retailcrm.ru
RETAILCRM_API_KEY=
# Код магазина (если в аккаунте несколько сайтов). См. Настройки → Магазины.
RETAILCRM_SITE=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Защита /api/sync (Vercel Cron шлёт Authorization: Bearer CRON_SECRET)
CRON_SECRET=generate-long-random-string

# Вебхук RetailCRM → /api/retailcrm-webhook?token=...
RETAILCRM_WEBHOOK_SECRET=

# Telegram (переменная API_KEY_BOT или TELEGRAM_BOT_TOKEN)
API_KEY_BOT=
TELEGRAM_CHANNEL_ID=
